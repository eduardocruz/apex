# A throwaway wallet — DO NOT use any wallet that holds real funds.
# Generate a fresh one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Prefix with 0x and paste below.
PRIVATE_KEY=0x

# Optional. Defaults to 0G Galileo Testnet.
# Mainnet: https://evmrpc.0g.ai
ZG_RPC_URL=https://evmrpc-testnet.0g.ai

# Optional. UI server port. Default 5757.
PORT=5757
